# ═══════════════════════════════════════════════════════════════════════════════
# CMO 360° PLATFORM — VARIÁVEIS DE AMBIENTE
# ═══════════════════════════════════════════════════════════════════════════════
# Copie este arquivo para .env e preencha com suas credenciais reais
# ═══════════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────────
# SUPABASE (Obrigatório)
# ───────────────────────────────────────────────────────────────────────────────

SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9... SUA-CHAVE-SERVICE-ROLE
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9... SUA-CHAVE-ANON


# ───────────────────────────────────────────────────────────────────────────────
# IA GENERATIVA (Opcional — recomendado)
# ───────────────────────────────────────────────────────────────────────────────

GROQ_API_KEY=gsk-xxxxxxxxxxxxxxxxxxxxxxxx


# ───────────────────────────────────────────────────────────────────────────────
# SEGURANÇA (Obrigatório para produção)
# ───────────────────────────────────────────────────────────────────────────────

SECRET_KEY=your-secret-key-min-32-characters-long-change-in-production


# ═══════════════════════════════════════════════════════════════════════════════
# INSTRUÇÕES
# ═══════════════════════════════════════════════════════════════════════════════
#
# 1. Copie este arquivo para .env:
#    cp .env.example .env
#
# 2. Edite .env com suas credenciais do Supabase
#
# 3. Para obter credenciais do Supabase:
#    - Acesse: https://supabase.com/dashboard
#    - Selecione seu projeto
#    - Vá em: Project Settings > API
#    - Copie Project URL → SUPABASE_URL
#    - Copie service_role key → SUPABASE_KEY
#    - Copie anon key → SUPABASE_ANON_KEY
#
# 4. (Opcional) Obtenha GROQ_API_KEY em: https://console.groq.com/keys
#
# ═══════════════════════════════════════════════════════════════════════════════
