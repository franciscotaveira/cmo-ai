# ═══════════════════════════════════════════════════════════════════════════════
# CMO 360° v6.1 — ARQUIVO .ENV COMPLETO
# ═══════════════════════════════════════════════════════════════════════════════
# EDITE ESTE ARQUIVO COM SUAS CREDENCIAIS REAIS
# NUNCA COMMIT ESTE ARQUIVO NO GIT (está no .gitignore)
# ═══════════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────────
# 1. SUPABASE (Obrigatório)
# ───────────────────────────────────────────────────────────────────────────────
# Obtenha em: https://supabase.com/dashboard > Project Settings > API

SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9... SUA-CHAVE-SERVICE-ROLE
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9... SUA-CHAVE-ANON


# ───────────────────────────────────────────────────────────────────────────────
# 2. CAMINHOS LOCAIS (Obrigatório)
# ───────────────────────────────────────────────────────────────────────────────
# Use barras normais (/) mesmo no Windows

# Pasta onde você coloca arquivos CSV/Excel para processamento
PATH_TO_DRIVE=C:/Users/Marketing/Documents/Antigravity/drive_input

# Pasta do Obsidian onde os dashboards serão criados
PATH_TO_OBSIDIAN=C:/Users/Marketing/Documents/Antigravity/obsidian_vault


# ───────────────────────────────────────────────────────────────────────────────
# 3. NOTIFICAÇÕES POR E-MAIL (Opcional — v6.1)
# ───────────────────────────────────────────────────────────────────────────────
# Configuração SMTP para envio de alertas

# Servidor SMTP (Gmail, Outlook, etc.)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Sua conta de e-mail
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=sua-senha-de-app  # Senha de app, não a senha normal!

# E-mail de envio (aparece no "De:")
EMAIL_FROM=alertas@cmo360.com
EMAIL_FROM_NAME=CMO 360° Alertas

# E-mail para testes
TEST_EMAIL=seu-email@gmail.com


# ───────────────────────────────────────────────────────────────────────────────
# 4. IA GENERATIVA (Opcional — v5.2)
# ───────────────────────────────────────────────────────────────────────────────

# Provedor: groq (recomendado, grátis), openai, anthropic, ollama
LLM_PROVIDER=groq

# Groq API Key (GRÁTIS — obtenha em https://console.groq.com/keys)
GROQ_API_KEY=gsk-xxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (opcional)
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx

# Anthropic (opcional)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx


# ───────────────────────────────────────────────────────────────────────────────
# 5. CONFIGURAÇÕES DO ENGINE (Opcional)
# ───────────────────────────────────────────────────────────────────────────────

# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Monitorar subpastas recursivamente
WATCHER_RECURSIVE=true

# Intervalo do watcher (segundos)
WATCHER_INTERVAL=300

# Background tasks interval (segundos)
BACKGROUND_INTERVAL=300


# ───────────────────────────────────────────────────────────────────────────────
# 6. WEBHOOK (Opcional)
# ───────────────────────────────────────────────────────────────────────────────

# Porta do servidor de webhooks
WEBHOOK_PORT=8088


# ───────────────────────────────────────────────────────────────────────────────
# 7. FRONTEND (Opcional — v6.1)
# ───────────────────────────────────────────────────────────────────────────────

# URL da API para o frontend
VITE_API_URL=http://localhost:8000

# WebSocket URL para tempo real
VITE_WS_URL=ws://localhost:8000/ws/notifications


# ═══════════════════════════════════════════════════════════════════════════════
# INSTRUÇÕES DE PREENCHIMENTO
# ═══════════════════════════════════════════════════════════════════════════════
#
# 1. SUPABASE:
#    - Acesse: https://supabase.com/dashboard
#    - Selecione seu projeto
#    - Vá em: Project Settings > API
#    - Copie: Project URL → SUPABASE_URL
#    - Copie: service_role key → SUPABASE_KEY
#    - Copie: anon key → SUPABASE_ANON_KEY
#
# 2. PATH_TO_DRIVE e PATH_TO_OBSIDIAN:
#    - Crie as pastas no seu computador
#    - Use caminhos absolutos com barras normais (/)
#    - Exemplo: C:/Users/Marketing/Documents/Antigravity/drive_input
#
# 3. NOTIFICAÇÕES POR E-MAIL (SMTP):
#    - Gmail: https://myaccount.google.com/apppasswords
#      1. Ative 2FA na sua conta Google
#      2. Gere uma "Senha de App"
#      3. Use essa senha em SMTP_PASSWORD
#    - Outlook: https://account.microsoft.com/security
#      1. Ative 2FA
#      2. Gere senha de app
#
# 4. GROQ_API_KEY (IA Generativa):
#    - Acesse: https://console.groq.com/keys
#    - Crie conta (grátis)
#    - Crie API Key
#    - Copie e cole aqui
#
# 5. SALVE este arquivo como: .env
#    (sem o .example no final)
#
# ═══════════════════════════════════════════════════════════════════════════════
