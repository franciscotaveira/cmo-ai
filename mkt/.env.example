# ═══════════════════════════════════════════════════════════════════════════════
# CONFIGURAÇÃO CMO 360° — MARKETING DATA COMMAND CENTER
# ═══════════════════════════════════════════════════════════════════════════════

# 1. SUPABASE (OBRIGATÓRIO)
# Obtenha em: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://sua-url.supabase.co
SUPABASE_KEY=sua-chave-service-role-aqui

# 2. CAMINHOS DO SISTEMA (Windows)
# Use barras normais (/) ou duplas invertidas (\\)
PATH_TO_DRIVE=C:/Users/Marketing/Documents/Antigravity/drive_input
PATH_TO_OBSIDIAN=C:/Users/Marketing/Documents/Antigravity/obsidian_vault

# 3. INTELIGÊNCIA ARTIFICIAL (OPCIONAL)
# LLM_PROVIDER: 'groq' ou 'openai' ou 'openrouter' ou 'anthropic'
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-sua-chave-aqui
GROQ_API_KEY=gsk-sua-chave-aqui
# OPENAI_API_KEY=sk-sua-chave-aqui
# ANTHROPIC_API_KEY=sk-ant-sua-chave-aqui

# 4. CONFIGURAÇÃO TÉCNICA
# DEBUG: true/false
DEBUG=true
PORT=8088
PYTHONIOENCODING=utf-8
